<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de controle de atendimento na secretaria</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            background: #fff;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            text-align: center;
            width: min(900px, 100%);
        }

        h1 {
            margin-bottom: 25px;
            color: #333;
        }

        .button-group {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
        }

        button {
            min-width: 180px;
            padding: 12px;
            border: none;
            border-radius: 6px;
            background-color: #007BFF;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        button:hover {
            background-color: #0056b3;
        }

        button a {
            color: white;
            text-decoration: none;
            font-size: 16px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Login</h1>
        <div class="button-group">
            <button><a href="/discente">Aluno</a></button>
            <button><a href="/secretaria">Secretaria</a></button>
        </div>
    </div>
</body>
</html>