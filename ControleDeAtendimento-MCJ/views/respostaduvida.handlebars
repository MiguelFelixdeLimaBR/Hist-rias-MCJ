<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Responder dúvida</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            background: #fff;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            width: min(700px, 100%);
        }

        h1 {
            margin-bottom: 20px;
            color: #333;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        label {
            font-weight: bold;
            color: #444;
        }

        input {
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        button {
            padding: 10px 12px;
            border: none;
            border-radius: 6px;
            background-color: #007BFF;
            color: white;
            cursor: pointer;
            margin-top: 8px;
        }

        button:hover {
            background-color: #0056b3;
        }

        .link {
            display: inline-block;
            margin-top: 15px;
            color: #007BFF;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
        }

        .link:hover {
            color: #0056b3;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Enviar Resposta</h1>
        <form action="/secretaria/reponderduvidas/{{rsp.id}}?_method=PUT" method="POST">
            <label for="resposta">Resposta</label>
            <textarea id="resposta" name="resposta" rows="10" required></textarea>

            <label for="status">Status</label>
            <input type="text" id="status" name="status" required>

            <button type="submit">Enviar Resposta</button>
        </form>
        <a class="link" href="/secretaria/listarduvidas">Voltar</a>
    </div>
</body>
</html>